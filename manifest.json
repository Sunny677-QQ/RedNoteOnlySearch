{
  "manifest_version": 3,
  "name": "小红书专注模式(RedNote Focus)",
  "version": "1.0",
  "description": "帮助你专注于搜索，不会被推荐流分心。",
  "icons": {
    "16": "image16.png",
    "32": "image32.png",
    "48": "image48.png",
    "128": "image128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.xiaohongshu.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start"
    }
  ]
}